let GROQ_API_KEY = "enter your groq_api key";
let TO_EMAIL    = "enter your g-mail";



var TOPICS = [
  "New AI models & research",
  "Startups & funding",
  "Open source contributions (GSoC, small orgs, new repos)",
  "Tools & APIs (Groq, Ollama, HuggingFace etc.)"
];

function sendDailyAIBrief() {
  var today = Utilities.formatDate(
    new Date(),
    Session.getScriptTimeZone(),
    "EEEE, MMMM d, yyyy"
  );

  var systemPrompt =
    "You are an expert AI news curator. " +
    "Return ONLY a valid JSON object — no markdown, no backticks, no explanation. " +
    "The JSON must be exactly: {\"items\": [ ... ]} " +
    "Each item must have: title, category, summary, why_it_matters, source,liks of it " +
    "Categories must be one of: " +
    TOPICS.join(", ") +
    ". Generate  items covering all categories.";

  var userPrompt =
    "Generate the AI morning brief for " +
    today +
    ". Return JSON only.";

  var payload = JSON.stringify({
    model: "llama-3.3-70b-versatile",
    max_tokens: 2500,
    temperature: 0.7,
    messages: [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt }
    ]
  });

  var options = {
    method: "post",
    contentType: "application/json",
    headers: {
      Authorization: "Bearer " + GROQ_API_KEY
    },
    payload: payload,
    muteHttpExceptions: true
  };

  var res = UrlFetchApp.fetch(
    "https://api.groq.com/openai/v1/chat/completions",
    options
  );

  var resJson = JSON.parse(res.getContentText());
  var raw = resJson.choices[0].message.content;

  Logger.log("RAW RESPONSE: " + raw);

  raw = raw.replace(/```json/gi, "").replace(/```/g, "").trim();

  var parsed;

  try {
    parsed = JSON.parse(raw);
  } catch (e) {
    var match = raw.match(/\{[\s\S]*\}/);
    if (match) {
      parsed = JSON.parse(match[0])
    } else {
      GmailApp.sendEmail(
        TO_EMAIL,
        "Error",
        "Could not parse response:\n\n" + raw
      );
      return;
    }
  }

  var items = parsed.items || [];

  if (items.length === 0) {
    GmailApp.sendEmail(
      TO_EMAIL,
      "Error",
      "No items found in response"
    );
    return;
  }

  var body = "AI Brief for " + today + "\n\n";

  items.forEach((item, i) => {
    body += `${i + 1}. ${item.title}\n`;
    body += `   ${item.summary}\n`;
    body += `   Why: ${item.why_it_matters}\n`;
    body += `   Source: ${item.source}\n`;
    body += `   Link:${item.link}\n\n`
  });

  GmailApp.sendEmail(
    TO_EMAIL,
    "AI Morning Brief",
    body
  );
}
